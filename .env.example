# Copy to .env and adjust. The compose stack and the Go binary read these.

# --- Postgres (deploy/docker-compose.yml) ---
POSTGRES_USER=ais
POSTGRES_PASSWORD=ais
POSTGRES_DB=ais
POSTGRES_PORT=5432

# --- Application (cmd/tracker) ---
# Connection string the service uses to reach Postgres.
DATABASE_URL=postgres://ais:ais@localhost:5432/ais?sslmode=disable

APP_ENV=dev            # dev | prod
HTTP_PORT=8080
LOG_LEVEL=info         # debug | info | warn | error
LOG_FORMAT=text        # text | json
SHUTDOWN_GRACE_SECONDS=30

# --- AIS sources (Phase 1) ---
# Optional; AISStream allows anonymous connections at lower rate limits.
AISSTREAM_API_KEY=

# --- Alerts (Phase 5) ---
# Optional; set both to enable the Telegram alert dispatch adapter.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
